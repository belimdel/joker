DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Envoi des emails de vérification (compte Gmail + mot de passe d'application).
# Si SMTP_USER/SMTP_PASS sont absents, le serveur passe en mode dégradé : les
# codes de vérification sont loggués en console (dev local sans SMTP).
SMTP_USER=adresse@gmail.com
SMTP_PASS=motdepasseapplication
