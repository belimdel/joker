# ─────────────────────────────────────────────────────────────────────────
# Modèle de configuration pour l'auto-hébergement Docker.
# Copier en `.env` (gitignoré) et remplir les valeurs. NE JAMAIS committer
# le vrai .env.
# ─────────────────────────────────────────────────────────────────────────

# Base de données PostgreSQL (Neon). Laisser VIDE = mode dégradé sans
# persistance (le serveur démarre quand même, mais ni comptes ni historique).
# ⚠️ En prod : brancher la branche Neon de PRODUCTION. Pour tester en local :
# la branche Neon DEV, jamais la prod.
DATABASE_URL=

# SMTP Gmail pour l'envoi des codes de vérification. Vides = mode dégradé
# (codes affichés dans les logs, aucun mail envoyé).
SMTP_USER=
SMTP_PASS=

# Domaine public (DuckDNS) servi par Caddy en HTTPS. Ex. joker-xxxx.duckdns.org
JOKER_DOMAIN=

# Origine autorisée pour Socket.IO/CORS. En prod, le client est servi par
# Express sur le même domaine → mettre l'URL HTTPS publique complète.
# Ex. https://joker-xxxx.duckdns.org
CLIENT_URL=

# Port interne d'écoute de l'app (Caddy proxifie vers ce port). 3001 par défaut.
PORT=3001

# Environnement : DOIT rester "production" pour l'auto-hébergement
# (active les cookies `secure`, etc.).
NODE_ENV=production
