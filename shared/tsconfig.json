{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "composite": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["."],
  "exclude": ["dist", "**/*.test.ts", "run-all-tests.ts"]
}